<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<key>CFBundleDevelopmentRegion</key>
		<string>$(DEVELOPMENT_LANGUAGE)</string>
		<key>CFBundleDisplayName</key>
		<string>Eatsy</string>
		<key>CFBundleExecutable</key>
		<string>$(EXECUTABLE_NAME)</string>
		<key>CFBundleIdentifier</key>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
		<!-- Handles the io.eatsy.app://reset-password deep link that
		     Supabase's password-reset email opens (see
		     auth_controller.dart's sendPasswordResetEmail redirectTo).
		     Without this, tapping the emailed link does nothing on iOS —
		     the app never even opens. Android's equivalent is the second
		     intent-filter in AndroidManifest.xml. -->
		<key>CFBundleURLTypes</key>
		<array>
			<dict>
				<key>CFBundleURLName</key>
				<string>io.eatsy.app</string>
				<key>CFBundleURLSchemes</key>
				<array>
					<string>io.eatsy.app</string>
				</array>
			</dict>
		</array>
		<key>CFBundleInfoDictionaryVersion</key>
		<string>6.0</string>
		<key>CFBundleName</key>
		<string>eatsy</string>
		<key>CFBundlePackageType</key>
		<string>APPL</string>
		<key>CFBundleShortVersionString</key>
		<string>$(FLUTTER_BUILD_NAME)</string>
		<key>CFBundleSignature</key>
		<string>????</string>
		<key>CFBundleVersion</key>
		<string>$(FLUTTER_BUILD_NUMBER)</string>
		<!-- Required by the health package for HealthKit access (steps,
		     active calories, heart rate, sleep, weight — see
		     lib/core/services/health_service.dart). App Store review
		     rejects apps that request HealthKit without both of these
		     present, and the wording must clearly explain the actual
		     reason to the person, not be generic boilerplate. -->
		<key>NSHealthShareUsageDescription</key>
		<string>Eatsy reads your steps, active calories, heart rate, sleep, and weight from Apple Health to personalize your nutrition targets and show your daily activity alongside your food log.</string>
		<key>NSHealthUpdateUsageDescription</key>
		<string>Eatsy does not currently write any data back to Apple Health. This permission is requested by the health package's shared authorization flow but is unused.</string>
		<key>LSRequiresIPhoneOS</key>
		<true/>
		<key>UILaunchStoryboardName</key>
		<string>LaunchScreen</string>
		<key>UIMainStoryboardFile</key>
		<string>Main</string>
		<key>UISupportedInterfaceOrientations</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>UISupportedInterfaceOrientations~ipad</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationPortraitUpsideDown</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>CADisableMinimumFrameDurationOnPhone</key>
		<true/>
		<key>UIApplicationSupportsIndirectInputEvents</key>
		<true/>
		<key>UIStatusBarHidden</key>
		<false/>
	</dict>
</plist>
